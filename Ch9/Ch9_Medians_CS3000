def find_minimum_and_max(a):
    n = len(a)
    if n == 0:
        return None, None  #if empty

    minimum = maximum = a[0]

    for i in range(1, n): #loop and update
        if a[i] < minimum:
            minimum = a[i]
        elif a[i] > maximum:
            maximum = a[i]

    return minimum, maximum

def measure_time(a):
    #minimum
    start_time = time.time()
    minimum_time = find_minimum(a)
    find_minimum_time = time.time() - start_time

    #max 
    start_time = time.time()
    max_time = find_max(a)
    find_max_time = time.time() - start_time

    #minimum and max 
    start_time = time.time()
    minimum_and_max_time = find_minimum_and_max(a)
    find_minimum_and_max_time = time.time() - start_time

    return find_minimum_time, find_max_time, find_minimum_and_max_time


def find_minimum(a):
    n = len(a) #n num of elements
    minimum = a[0] #0 indexing, 1st element
    for i in range(1,n):
        if minimum > a[i]:
            minimum = a[i]
    return minimum

def find_max(a):
    n = len(a)
    maximum = a[0] #1st element for now
    for i in range(1,n):
        if maximum < a[i]:
            maximum = a[i]
    return maximum


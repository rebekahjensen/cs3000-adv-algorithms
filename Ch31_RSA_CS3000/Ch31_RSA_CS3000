#from ch 31
def mod_exp(a,b,n):
    d = 1
    binary_b = bin(b)[2:] #b to binary str

    for bit in binary_b:
        d = (d*d) %n #sqaure d mod n
        if bit == '1':
            d = (d*a) %n
    return d 


def pseudoprime(n): #first prime checker
    if mod_exp(2, n-1, n) != 1:
        return False #not prime
    else:
        return True 
    
def create_prime():
    while True:
        rand = random.randint(2*1023, 2**1024) #2 primes
        if pseudoprime(rand): #1st prime check
            if sympy.isprime(rand): #2nd prime check
                return rand
    

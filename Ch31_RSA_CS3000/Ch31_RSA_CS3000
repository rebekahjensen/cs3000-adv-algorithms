#from ch 31
def euclid(a,b):
    if b == 0:
        return a
    else:
        return euclid(b, a%b)

def extend_euclid(a,b):
    if b == 0:
        return a,1,0
    else:
        d_prime,x_prime,y_prime = extend_euclid(b,a%b)
        d = d_prime
        x = y_prime
        y = x_prime - (a//b) * y_prime
        return d,x,y
    

from matplotlib import pyplot as plt
import time
import random

def rand_int(n): #generate random ints
    n1 = random.randint(0, 10**n - 1) #n digit number
    n2 = random.randint(0, 10**n - 1)
    return n1, n2
    
def mult_int(n1, n2):
#how long to multiply 2 random n digits
    return n1 * n2

def divis_int(n1, n2):
#how long to divide 2 random n digits
    if n2 != 0: #can't divide 1/0 = undefined
          return n1 / n2
    else:        
        return float("inf")
    
def measure_time(n):
    n1, n2 = rand_int(n)
    iterations = 100000 #pls work

    #timing multiplication
    startTime = time.time()
    for _ in range(iterations):
        mult_int(n1, n2)

    # mult_int(n1,n2)
    mult_rec_time = (time.time() - startTime) / iterations

    #timing division
    startTime = time.time()
    for _ in range(iterations):
        divis_int(n1, n2)
    # divis_int(n1,n2)
    divis_rec_time = (time.time() - startTime) / iterations

    return mult_rec_time, divis_rec_time

